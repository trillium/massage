# E2E Onboarding Test Environment
# Copy to .env.test.local and fill in real values
# Used by: pnpm test:e2e --project=onboarding-live

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

TEST_ADMIN_EMAIL=trillium@trilliumsmith.com
TEST_ADMIN_PASSWORD=

# Optional: set to run manual Google OAuth in headed mode
# HEADED_OAUTH=1

# Optional: keep test tenant schema after run for debugging
# SKIP_TEARDOWN=1
