{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "entry": [
    "app/**/page.tsx",
    "app/**/layout.tsx",
    "app/**/route.ts",
    "app/**/loading.tsx",
    "app/**/error.tsx",
    "app/**/not-found.tsx",
    "proxy.ts",
    "contentlayer.config.ts",
    "next.config.js",
    "vitest.config.ts",
    "vitest.setup.ts",
    "scripts/*.{ts,mjs,js}",
    "mcp-server.ts",
    "src/lib/mcp/**/*.ts",
    "data/**/*.mdx"
  ],
  "ignorePatterns": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "tests/**",
    "scripts/**",
    "playground/**",
    ".contentlayer/**",
    ".next/**",
    "dist/**",
    "build/**",
    "node_modules/**",
    "data/ratings.ts"
  ],
  "ignoreDependencies": [
    "autoprefixer",
    "@svgr/webpack",
    "ignore-loader",
    "lint-staged",
    "dictionary-en",
    "nspell",
    "eslint-config-next",
    "@tailwindcss/forms",
    "@tailwindcss/typography",
    "maplibre-gl",
    "canvas",
    "@axe-core/playwright",
    "contentlayer2",
    "next-contentlayer2",
    "hast-util-from-html-isomorphic",
    "reading-time",
    "rehype-autolink-headings",
    "rehype-citation",
    "rehype-katex",
    "rehype-katex-notranslate",
    "rehype-preset-minify",
    "rehype-prism-plus",
    "rehype-slug",
    "remark-gfm",
    "remark-math"
  ],
  "rules": {
    "unused-files": "warn",
    "unused-exports": "warn",
    "unused-types": "warn",
    "duplicates": "warn",
    "circular-deps": "error",
    "boundary-violations": "error"
  },
  "duplicates": {
    "threshold": 20,
    "mode": "semantic"
  },
  "health": {
    "maxCyclomatic": 20,
    "maxCognitive": 15,
    "maxCrap": 50
  }
}
