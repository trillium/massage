{
  "name": "trillium-massage",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "next dev",
    "dev": "cross-env INIT_CWD=$PWD next dev --port 9876 --hostname 0.0.0.0",
    "build": "cross-env INIT_CWD=$PWD next build --webpack && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "build:staged": "./scripts/build-staged.sh",
    "build:staged:verbose": "./scripts/build-staged.sh --verbose",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "lint": "biome check --write app components lib layouts scripts",
    "prepare": "husky",
    "test": "vitest run --changed --reporter=dot",
    "test:all": "vitest run --reporter=dot",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "dev:e2e": "cross-env INIT_CWD=$PWD E2E_MOCK_EVENTS=true next dev --port 9999",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "ratings:spellcheck": "ts-node scripts/ratingsCorrectionScript.ts",
    "dead-code": "knip --reporter markdown > dead-code-report.md; echo 'Report: dead-code-report.md'",
    "spellcheck": "cspell '**/*.{ts,tsx,js,jsx,md,mdx}' --no-progress",
    "spellcheck:fix": "cspell '**/*.{ts,tsx,js,jsx,md,mdx}' --no-progress --show-suggestions",
    "commit:build": "git config hooks.prebuild true && git commit",
    "commit:no-build": "git config hooks.prebuild false && git commit",
    "generate-static-map": "ts-node scripts/generate-la-map-auto.ts",
    "cspell:ignore": "./scripts/cspell-ignore-and-prettier.sh",
    "convert-images": "bash ./scripts/convert_and_resize_images.sh",
    "db:backup": "tsx scripts/backup-db.ts",
    "admin:generate-link": "tsx scripts/generate-admin-link.ts --emailEnv",
    "user:generate-link": "tsx scripts/generate-user-link.ts",
    "push:send-test-message": "tsx scripts/send-test-pushover.ts",
    "blog:build": "contentlayer2 build && cross-env NODE_OPTIONS='--experimental-json-modules' node ./scripts/postbuild.mjs",
    "blog:watch": "contentlayer2 dev",
    "render:proposal": "tsx scripts/render-proposal.ts",
    "render:proposal:pdf": "tsx scripts/render-proposal-pdf.ts"
  },
  "dependencies": {
    "@headlessui/react": "2.2.0",
    "@heroicons/react": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.21.0",
    "@next/bundle-analyzer": "15.2.4",
    "@reduxjs/toolkit": "^2.5.0",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.80.0",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/postcss": "^4.0.5",
    "@tailwindcss/typography": "^0.5.15",
    "@types/qrcode": "^1.5.6",
    "@vis.gl/react-maplibre": "^8.0.4",
    "@vvo/tzdb": "^6.157.0",
    "autoprefixer": "^10.4.13",
    "body-scroll-lock": "^4.0.0-beta.0",
    "clsx": "^2.1.1",
    "contentlayer2": "0.5.5",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.1",
    "esbuild": "0.25.2",
    "formik": "^2.4.6",
    "github-slugger": "^2.0.0",
    "googleapis": "^157.0.0",
    "gray-matter": "^4.0.2",
    "handlebars": "^4.7.8",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "image-size": "2.0.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.1.0",
    "kbar": "0.1.0-beta.45",
    "lru-cache": "^11.0.2",
    "maplibre-gl": "^5.6.2",
    "next": "16.0.7",
    "next-contentlayer2": "0.5.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^6.9.16",
    "pliny": "0.4.1",
    "postcss": "^8.4.24",
    "posthog-js": "^1.258.2",
    "posthog-node": "^4.18.0",
    "qr-code-styling": "^1.9.2",
    "qrcode": "^1.5.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.2.0",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.3.0",
    "rehype-katex": "^7.0.0",
    "rehype-katex-notranslate": "^1.1.4",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.0",
    "remark-gfm": "^4.0.0",
    "remark-github-blockquote-alert": "^1.2.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.0.5",
    "unist-util-visit": "^5.0.0",
    "wicg-inert": "^3.1.3",
    "zod": "^4.0.10",
    "zod-formik-adapter": "^1.3.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@biomejs/biome": "^2.4.2",
    "@faker-js/faker": "^9.3.0",
    "@jest/types": "^29.6.3",
    "@playwright/test": "^1.56.1",
    "@svgr/webpack": "^8.0.1",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/cli-progress": "^3.11.6",
    "@types/handlebars": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.0",
    "@types/mdx": "^2.0.12",
    "@types/node": "^25.3.0",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.10",
    "@types/react": "^19.0.8",
    "@typescript/native-preview": "7.0.0-dev.20260217.1",
    "@vitest/coverage-v8": "^3.2.3",
    "@vitest/ui": "^3.2.3",
    "canvas": "^3.2.1",
    "cli-progress": "^3.12.0",
    "cross-env": "^7.0.3",
    "cspell": "^9.2.0",
    "dictionary-en": "^4.0.0",
    "happy-dom": "^20.8.3",
    "husky": "^9.1.7",
    "ignore-loader": "^0.1.2",
    "jest-environment-jsdom": "^29.7.0",
    "knip": "^5.83.1",
    "lint-staged": "^13.3.0",
    "msw": "^2.10.4",
    "nspell": "^2.1.5",
    "playwright": "^1.56.1",
    "prettier": "^3.4.2",
    "puppeteer": "^24.16.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.4",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.3"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "biome check --write --no-errors-on-unmatched",
      "bash -c '.husky/tsc-staged.sh'",
      "bash -c 'cspell --no-progress \"$@\" || exit 0' --"
    ],
    "*.+(json|css)": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.+(md|mdx)": [
      "prettier --write",
      "bash -c 'cspell --no-progress \"$@\" || exit 0' --"
    ]
  },
  "packageManager": "pnpm@9.15.0"
}
