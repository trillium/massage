#!/bin/sh

if [ "${CI:-}" = "true" ] || [ "${GITHUB_ACTIONS:-}" = "true" ]; then
  exit 0
fi


if [ -f scripts/fallow-prepush.sh ]; then
  bash scripts/fallow-prepush.sh
fi

if curl -s http://localhost:9876/ > /dev/null 2>&1; then
  pnpm check-overflow || {
    echo "check-overflow: horizontal overflow detected — push blocked"
    exit 1
  }
else
  echo "check-overflow: dev server not running, skipping overflow check"
fi

if command -v gitleaks &>/dev/null; then
  gitleaks protect --staged --no-banner || {
    echo "gitleaks: secrets detected — push blocked"
    exit 1
  }
else
  echo "gitleaks: not installed, skipping secret scan (brew install gitleaks)"
fi
